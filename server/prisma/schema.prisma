generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GATE_OPERATOR
  LOGISTICS_PLANNER
  REPORTING_MANAGER
  SORTING_EMPLOYEE
  ADMIN
  SALES
  QC_INSPECTOR
  LOGISTICS_COORDINATOR
  FINANCE_USER
  FINANCE_MANAGER
  COMPLIANCE_OFFICER
}

enum OrderStatus {
  PLANNED
  ARRIVED
  IN_PROGRESS
  DISPUTE
  COMPLETED
  INVOICED
  CANCELLED
}

enum InboundStatus {
  ARRIVED
  WEIGHED_IN
  WEIGHED_OUT
  READY_FOR_SORTING
  SORTED
}

enum SortingStatus {
  PLANNED
  SORTED
}

enum SupplierType {
  PRIVATE_INDIVIDUAL
  PRO
  THIRD_PARTY
}

enum IncidentCategory {
  DAMAGE
  DISPUTE
  SPECIAL_HANDLING
  DRIVER_INSTRUCTION
}

enum WeightAmendmentReason {
  CALIBRATION_ERROR
  EQUIPMENT_MALFUNCTION
  INCORRECT_READING
  SUPERVISOR_CORRECTION
  OTHER
}

enum MatchStrategy {
  EXACT_SAME_DAY
  EXACT_WINDOW
  MANUAL
  AD_HOC
}

enum WorkflowStageStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum ProcessingRecordStatus {
  DRAFT
  FINALIZED
  CONFIRMED
  SUPERSEDED
}

enum TreatmentRoute {
  RECYCLED
  REUSED
  DISPOSED
}

enum AcceptantStage {
  FIRST_ACCEPTANT
  FOLLOWING
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  INACTIVE
}

enum InvoicingFrequency {
  PER_ORDER
  WEEKLY
  MONTHLY
  QUARTERLY
}

enum PricingModel {
  WEIGHT
  QUANTITY
}

enum FeeRateType {
  FIXED
  PERCENTAGE
  PER_KG
  PER_HOUR
}

enum SkipType {
  OPEN_TOP
  CLOSED_TOP
  GITTERBOX
  PALLET
  OTHER
}

enum ParcelType {
  CONTAINER
  MATERIAL
}

enum WeighingMode {
  SWAP
  DIRECT
  BULK
}

enum InvoiceStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

enum ContaminationType {
  NON_WEEE
  HAZARDOUS
  EXCESSIVE_MOISTURE
  SORTING_REQUIRED
}

enum EntityStatus {
  ACTIVE
  INACTIVE
}

enum SupplierRole {
  ONTDOENER
  ONTVANGER
  HANDELAAR
  BEMIDDELAAR
}

enum EntitySupplierType {
  PRO
  COMMERCIAL
  AD_HOC
}

enum ContractType {
  INCOMING
  OUTGOING
}

enum ShipmentType {
  DOMESTIC_NL
  EU_CROSS_BORDER
}

enum OutboundOrderStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  INVOICED
  CANCELLED
}

enum OutboundStatus {
  CREATED
  LOADING
  WEIGHED
  DOCUMENTS_READY
  DEPARTED
  DELIVERED
}

enum OutboundWeighingType {
  GROSS
  TARE
}

enum WeighingSource {
  SCALE
  MANUAL
}

enum OutboundDocumentType {
  BEGELEIDINGSBRIEF
}

enum DocumentGenerationStatus {
  PENDING
  GENERATED
  FAILED
}

enum OrderDocumentType {
  BEGELEIDINGSBRIEF
  WEIGHT_TICKET
  OTHER
}

enum OutboundParcelStatus {
  AVAILABLE
  ASSIGNED
  SHIPPED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password_hash String
  full_name     String
  role          Role
  is_active     Boolean   @default(true)
  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  orders_created     InboundOrder[]
  inbounds_confirmed Inbound[]
  sessions_recorded  SortingSession[]
  reports_generated  Report[]
  audit_logs         AuditLog[]
  notifications      Notification[]
  weight_amendments  WeightAmendment[] @relation("WeightAmendments")

  invoices_created         Invoice[]
  contamination_incidents  ContaminationIncident[]
  outbound_orders_created  OutboundOrder[]
}

model Carrier {
  id             String   @id @default(uuid())
  name           String
  kvk_number     String?
  contact_name   String?
  contact_email  String?
  contact_phone  String?
  licence_number String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())

  orders                InboundOrder[]
  vehicles              Vehicle[]
  contracts             SupplierContract[]
  migrated_to_entity_id String?
}

model Supplier {
  id                      String       @id @default(uuid())
  name                    String
  supplier_type           SupplierType
  kvk_number              String?
  btw_number              String?
  iban                    String?
  contact_name            String?
  contact_email           String?
  contact_phone           String?
  address                 String?
  vihb_number             String?
  pro_registration_number String?
  is_active               Boolean      @default(true)
  created_at              DateTime     @default(now())

  orders                InboundOrder[]
  afvalstroomnummers    SupplierAfvalstroomnummer[]
  contracts             SupplierContract[]
  invoices              Invoice[]
  migrated_to_entity_id String?
}

model Entity {
  id                          String       @id @default(uuid())
  company_name                String
  street_and_number           String
  postal_code                 String
  city                        String
  country                     String       @default("NL")
  kvk_number                  String?
  btw_number                  String?
  iban                        String?
  vihb_number                 String?
  environmental_permit_number String?
  contact_name                String?
  contact_email               String?
  contact_phone               String?
  status                      EntityStatus @default(ACTIVE)

  is_supplier    Boolean @default(false)
  is_transporter Boolean @default(false)
  is_disposer    Boolean @default(false)
  is_receiver    Boolean @default(false)

  supplier_type           EntitySupplierType?
  supplier_roles          SupplierRole[]
  pro_registration_number String?

  is_also_site  Boolean @default(false)
  is_protected  Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  disposer_sites DisposerSite[]

  contracts_as_supplier       SupplierContract[] @relation("ContractSupplier")
  contracts_as_transporter    SupplierContract[] @relation("ContractTransporter")
  contracts_as_invoice_entity SupplierContract[] @relation("ContractInvoiceEntity")
  contracts_as_buyer          SupplierContract[] @relation("ContractBuyer")
  contracts_as_sender         SupplierContract[] @relation("ContractSender")
  contracts_as_disposer       SupplierContract[] @relation("ContractDisposer")
  orders_as_supplier          InboundOrder[]     @relation("OrderSupplier")
  orders_as_transporter       InboundOrder[]     @relation("OrderTransporter")

  contract_waste_streams_as_receiver ContractWasteStream[] @relation("CWSReceiver")

  outbound_orders_as_buyer                OutboundOrder[] @relation("OutboundOrderBuyer")
  outbound_orders_as_sender               OutboundOrder[] @relation("OutboundOrderSender")
  outbound_orders_as_disposer             OutboundOrder[] @relation("OutboundOrderDisposer")
  outbound_orders_as_transporter          OutboundOrder[] @relation("OutboundOrderTransporter")
  outbound_orders_as_outsourced_transporter OutboundOrder[] @relation("OutboundOrderOutsourcedTransporter")

  outbound_order_waste_streams_as_receiver OutboundOrderWasteStream[] @relation("OOWSReceiver")
}

model DisposerSite {
  id                          String       @id @default(uuid())
  entity_id                   String
  site_name                   String
  street_and_number           String
  postal_code                 String
  city                        String
  country                     String       @default("NL")
  environmental_permit_number String?
  status                      EntityStatus @default(ACTIVE)
  created_at                  DateTime     @default(now())
  updated_at                  DateTime     @updatedAt

  entity          Entity             @relation(fields: [entity_id], references: [id])
  contracts       SupplierContract[] @relation("ContractDisposerSite")
  outbound_orders OutboundOrder[]    @relation("OutboundOrderDisposerSite")
}

model Vehicle {
  id                 String   @id @default(uuid())
  registration_plate String   @unique
  carrier_id         String
  type               String?
  created_at         DateTime @default(now())

  carrier  Carrier   @relation(fields: [carrier_id], references: [id])
  inbounds Inbound[]
}

model WasteStream {
  id             String   @id @default(uuid())
  name           String
  code           String   @unique
  cbs_code       String?
  weeelabex_code String?
  ewc_code       String?
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())

  orders                      InboundOrder[]
  categories                  ProductCategory[]
  inbounds                    Inbound[]
  assets                      Asset[]
  order_waste_streams         OrderWasteStream[]
  supplier_afvalstroomnummers SupplierAfvalstroomnummer[]
  materials                   MaterialMaster[]
  contract_waste_streams      ContractWasteStream[]
  outbound_order_waste_streams OutboundOrderWasteStream[]
}

model ProductCategory {
  id                   String   @id @default(uuid())
  code_cbs             String   @unique
  description_en       String
  description_nl       String
  waste_stream_id      String
  recycled_pct_default Decimal  @default(0)
  reused_pct_default   Decimal  @default(0)
  disposed_pct_default Decimal  @default(0)
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())

  waste_stream    WasteStream      @relation(fields: [waste_stream_id], references: [id])
  sorting_lines   SortingLine[]
  material_assets Asset[]          @relation("MaterialCategory")
  materials       MaterialMaster[] @relation("LegacyMaterialCategory")
}

model InboundOrder {
  id                        String            @id @default(uuid())
  order_number              String            @unique
  carrier_id                String
  supplier_id               String
  planned_date              DateTime
  planned_time_window_start DateTime?
  planned_time_window_end   DateTime?
  expected_skip_count       Int               @default(1)
  waste_stream_id           String
  vehicle_plate             String?
  afvalstroomnummer         String?
  notes                     String?
  status                    OrderStatus       @default(PLANNED)
  is_adhoc                  Boolean           @default(false)
  is_lzv                    Boolean           @default(false)
  client_reference          String?
  adhoc_person_name         String?
  adhoc_id_reference        String?
  incident_category         IncidentCategory?
  incident_notes            String?
  received_asset_count      Int               @default(0)
  created_by                String
  created_at                DateTime          @default(now())
  updated_at                DateTime          @updatedAt

  entity_supplier_id String?
  transporter_id     String?

  carrier                 Carrier                 @relation(fields: [carrier_id], references: [id])
  supplier                Supplier                @relation(fields: [supplier_id], references: [id])
  waste_stream            WasteStream             @relation(fields: [waste_stream_id], references: [id])
  created_by_user         User                    @relation(fields: [created_by], references: [id])
  entity_supplier         Entity?                 @relation("OrderSupplier", fields: [entity_supplier_id], references: [id])
  transporter             Entity?                 @relation("OrderTransporter", fields: [transporter_id], references: [id])
  inbounds                Inbound[]
  waste_streams           OrderWasteStream[]
  documents               OrderDocument[]
  invoice_lines           InvoiceLine[]
  contamination_incidents ContaminationIncident[]
}

model OrderWasteStream {
  id                String   @id @default(uuid())
  order_id          String
  waste_stream_id   String
  afvalstroomnummer String?
  planned_amount_kg Decimal? @db.Decimal(12, 2)

  order        InboundOrder @relation(fields: [order_id], references: [id])
  waste_stream WasteStream  @relation(fields: [waste_stream_id], references: [id])

  @@unique([order_id, waste_stream_id])
}

model OrderDocument {
  id            String            @id @default(uuid())
  order_id      String
  document_type OrderDocumentType
  file_name     String
  file_size     Int
  mime_type     String
  storage_path  String
  uploaded_by   String
  uploaded_at   DateTime          @default(now())

  order InboundOrder @relation(fields: [order_id], references: [id])
}

model Inbound {
  id                String            @id @default(uuid())
  inbound_number    String            @unique
  order_id          String
  vehicle_id        String
  waste_stream_id   String?
  arrived_at        DateTime          @default(now())
  gross_ticket_id   String?           @unique
  tare_ticket_id    String?           @unique
  gross_weight_kg   Decimal?
  tare_weight_kg    Decimal?
  net_weight_kg     Decimal?
  status            InboundStatus     @default(ARRIVED)
  confirmed_by      String?
  confirmed_at      DateTime?
  notes             String?
  incident_category IncidentCategory?
  match_strategy    MatchStrategy?
  matched_by        String?
  matched_at        DateTime?
  is_manual_match   Boolean           @default(false)
  device_id         String?
  weighing_mode     WeighingMode?

  order             InboundOrder      @relation(fields: [order_id], references: [id])
  vehicle           Vehicle           @relation(fields: [vehicle_id], references: [id])
  waste_stream      WasteStream?      @relation(fields: [waste_stream_id], references: [id])
  gross_ticket      PfisterTicket?    @relation("GrossTicket", fields: [gross_ticket_id], references: [id])
  tare_ticket       PfisterTicket?    @relation("TareTicket", fields: [tare_ticket_id], references: [id])
  confirmed_by_user User?             @relation(fields: [confirmed_by], references: [id])
  assets            Asset[]
  sorting_session   SortingSession?
  weighings         InboundWeighing[]

  @@map("WeighingEvent")
}

model InboundWeighing {
  id                String   @id @default(uuid())
  inbound_id        String
  sequence          Int
  pfister_ticket_id String   @unique
  weight_kg         Decimal
  is_tare           Boolean  @default(false)
  created_at        DateTime @default(now())

  inbound          Inbound       @relation(fields: [inbound_id], references: [id])
  pfister_ticket   PfisterTicket @relation(fields: [pfister_ticket_id], references: [id])
  gross_for_assets Asset[]       @relation("AssetGrossWeighing")
  tare_for_assets  Asset[]       @relation("AssetTareWeighing")

  @@unique([inbound_id, sequence])
}

model PfisterTicket {
  id                 String    @id @default(uuid())
  ticket_number      String    @unique
  weighing_type      String
  weight_kg          Decimal
  unit               String    @default("kg")
  timestamp          DateTime
  raw_payload        String
  is_manual_override Boolean   @default(false)
  override_reason    String?
  override_by        String?
  is_confirmed       Boolean   @default(false)
  confirmed_by       String?
  confirmed_at       DateTime?
  device_id          String?
  created_at         DateTime  @default(now())

  gross_inbound      Inbound?                @relation("GrossTicket")
  tare_inbound       Inbound?                @relation("TareTicket")
  inbound_weighing   InboundWeighing?
  amendments         WeightAmendment[]
  outbound_weighing  OutboundWeighingRecord?
}

model Asset {
  id                       String     @id @default(uuid())
  asset_label              String     @unique
  inbound_id               String     @map("weighing_event_id")
  parcel_type              ParcelType @default(CONTAINER)
  container_type           SkipType?  @map("skip_type")
  container_label          String?
  estimated_tare_weight_kg Decimal?
  material_category_id     String?
  waste_stream_id          String?
  sequence                 Int?
  estimated_volume_m3      Decimal?
  gross_weighing_id        String?
  tare_weighing_id         String?
  gross_weight_kg          Decimal?
  tare_weight_kg           Decimal?
  net_weight_kg            Decimal?
  notes                    String?
  created_at               DateTime   @default(now())

  inbound            Inbound               @relation(fields: [inbound_id], references: [id])
  waste_stream       WasteStream?          @relation(fields: [waste_stream_id], references: [id])
  material_category  ProductCategory?      @relation("MaterialCategory", fields: [material_category_id], references: [id])
  gross_weighing     InboundWeighing?      @relation("AssetGrossWeighing", fields: [gross_weighing_id], references: [id])
  tare_weighing      InboundWeighing?      @relation("AssetTareWeighing", fields: [tare_weighing_id], references: [id])
  sorting_lines      SortingLine[]
  catalogue_entries  AssetCatalogueEntry[]
  processing_records ProcessingRecord[]

  @@index([container_label])
}

model ContainerRegistry {
  id              String   @id @default(uuid())
  container_label String   @unique
  container_type  SkipType
  tare_weight_kg  Decimal
  volume_m3       Decimal?
  notes           String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}

model SortingSession {
  id                String              @id @default(uuid())
  inbound_id        String              @unique @map("weighing_event_id")
  order_id          String
  recorded_by       String
  recorded_at       DateTime            @default(now())
  status            SortingStatus       @default(PLANNED)
  catalogue_status  WorkflowStageStatus @default(NOT_STARTED)
  processing_status WorkflowStageStatus @default(NOT_STARTED)
  notes             String?

  inbound                 Inbound                 @relation(fields: [inbound_id], references: [id])
  recorded_by_user        User                    @relation(fields: [recorded_by], references: [id])
  sorting_lines           SortingLine[]
  catalogue_entries       AssetCatalogueEntry[]
  processing_records      ProcessingRecord[]
  contamination_incidents ContaminationIncident[]
}

model SortingLine {
  id            String  @id @default(uuid())
  session_id    String
  asset_id      String
  category_id   String
  net_weight_kg Decimal
  recycled_pct  Decimal
  reused_pct    Decimal
  disposed_pct  Decimal
  notes         String?

  session  SortingSession  @relation(fields: [session_id], references: [id])
  asset    Asset           @relation(fields: [asset_id], references: [id])
  category ProductCategory @relation(fields: [category_id], references: [id])
}

model Report {
  id              String   @id @default(uuid())
  type            String
  generated_by    String
  generated_at    DateTime @default(now())
  parameters_json Json
  file_path_pdf   String?
  file_path_xlsx  String?

  generated_by_user User @relation(fields: [generated_by], references: [id])
}

model ReportSchedule {
  id               String    @id @default(uuid())
  report_type      String
  frequency        String
  day_of_week      Int?
  day_of_month     Int?
  recipient_emails String[]
  format           String
  parameters_json  Json
  is_active        Boolean   @default(true)
  last_run_at      DateTime?
  next_run_at      DateTime
  created_at       DateTime  @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String
  action      String
  entity_type String
  entity_id   String
  diff_json   Json
  timestamp   DateTime @default(now())
  ip_address  String?

  user User @relation(fields: [user_id], references: [id])
}

model SystemSetting {
  id                     String   @id @default("singleton")
  facility_name          String   @default("Statice B.V.")
  facility_address       String   @default("Recyclingweg 1, 1234 AB Amsterdam")
  facility_permit_number String   @default("ST-2026-001")
  facility_kvk           String   @default("12345678")
  report_footer_text     String   @default("Statice B.V. — Confidential")
  max_skips_per_event    Int      @default(10)
  config_json            Json     @default("{}")
  updated_at             DateTime @updatedAt
}

model Notification {
  id          String   @id @default(uuid())
  user_id     String
  type        String
  title       String
  message     String
  entity_type String?
  entity_id   String?
  is_read     Boolean  @default(false)
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])
}

model PfisterIngressLog {
  id            String    @id @default(uuid())
  source        String
  protocol      String?
  payload       String
  status        String    @default("RECEIVED")
  error_message String?
  received_at   DateTime  @default(now())
  processed_at  DateTime?
}

model SupplierAfvalstroomnummer {
  id                String   @id @default(uuid())
  supplier_id       String
  afvalstroomnummer String
  waste_stream_id   String?
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())

  supplier     Supplier     @relation(fields: [supplier_id], references: [id])
  waste_stream WasteStream? @relation(fields: [waste_stream_id], references: [id])

  @@unique([supplier_id, afvalstroomnummer])
}

model WeightAmendment {
  id                 String                @id @default(uuid())
  pfister_ticket_id  String
  original_weight_kg Decimal
  amended_weight_kg  Decimal
  reason             WeightAmendmentReason
  reason_notes       String?
  amended_by         String
  created_at         DateTime              @default(now())

  pfister_ticket  PfisterTicket @relation(fields: [pfister_ticket_id], references: [id])
  amended_by_user User          @relation("WeightAmendments", fields: [amended_by], references: [id])
}

model MaterialMaster {
  id                          String   @id @default(uuid())
  code                        String   @unique
  name                        String
  waste_stream_id             String
  cbs_code                    String
  weeelabex_group             String
  eural_code                  String
  weee_category               String   @map("annex_iii_category")
  legacy_category_id          String?
  default_process_description String?
  average_weight_kg           Decimal? @db.Decimal(10, 3)
  is_active                   Boolean  @default(true)
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt

  waste_stream        WasteStream                         @relation(fields: [waste_stream_id], references: [id])
  legacy_category     ProductCategory?                    @relation("LegacyMaterialCategory", fields: [legacy_category_id], references: [id])
  catalogue_entries   AssetCatalogueEntry[]
  processing_records  ProcessingRecord[]
  certificate_scopes  ProcessorCertificateMaterialScope[]
  fractions           MaterialFraction[]
  reusable_items      ReusableItem[]
  contract_rate_lines ContractRateLine[]
  invoice_lines       InvoiceLine[]
  outbound_parcels    OutboundParcel[]

  @@map("ProductTypeMaster")
}

model FractionMaster {
  id                                  String         @id @default(uuid())
  code                                String         @unique
  name                                String
  eural_code                          String
  default_acceptant_stage             AcceptantStage @default(FIRST_ACCEPTANT)
  default_process_description         String?
  prepared_for_reuse_pct_default      Decimal        @default(0)
  recycling_pct_default               Decimal        @default(0)
  other_material_recovery_pct_default Decimal        @default(0)
  energy_recovery_pct_default         Decimal        @default(0)
  thermal_disposal_pct_default        Decimal        @default(0)
  is_active                           Boolean        @default(true)
  created_at                          DateTime       @default(now())
  updated_at                          DateTime       @updatedAt

  materials           MaterialFraction[]
  processing_outcomes ProcessingOutcomeLine[]
}

model MaterialFraction {
  id          String   @id @default(uuid())
  material_id String
  fraction_id String
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())

  material MaterialMaster @relation(fields: [material_id], references: [id])
  fraction FractionMaster @relation(fields: [fraction_id], references: [id])

  @@unique([material_id, fraction_id])
}

model AssetCatalogueEntry {
  id                      String   @id @default(uuid())
  session_id              String
  asset_id                String
  material_id             String   @map("product_type_id")
  weight_kg               Decimal
  reuse_eligible_quantity Int      @default(0)
  notes                   String?
  entry_order             Int      @default(0)
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  session            SortingSession     @relation(fields: [session_id], references: [id])
  asset              Asset              @relation(fields: [asset_id], references: [id])
  material           MaterialMaster     @relation(fields: [material_id], references: [id])
  processing_records ProcessingRecord[]
  reusable_items     ReusableItem[]

  @@index([session_id, asset_id])
}

model ProcessingRecord {
  id                     String                 @id @default(uuid())
  session_id             String
  asset_id               String
  catalogue_entry_id     String?
  material_id            String                 @map("product_type_id")
  material_code_snapshot String                 @map("product_code_snapshot")
  material_name_snapshot String                 @map("product_label_snapshot")
  weee_category_snapshot String                 @map("annex_iii_category_snapshot")
  status                 ProcessingRecordStatus @default(DRAFT)
  version_no             Int                    @default(1)
  is_current             Boolean                @default(true)
  supersedes_id          String?
  finalized_by           String?
  finalized_at           DateTime?
  confirmed_by           String?
  confirmed_at           DateTime?
  reason_code            String?
  reason_notes           String?
  balance_delta_kg       Decimal                @default(0)
  created_at             DateTime               @default(now())
  updated_at             DateTime               @updatedAt

  session         SortingSession          @relation(fields: [session_id], references: [id])
  asset           Asset                   @relation(fields: [asset_id], references: [id])
  catalogue_entry AssetCatalogueEntry?    @relation(fields: [catalogue_entry_id], references: [id])
  material        MaterialMaster          @relation(fields: [material_id], references: [id])
  outcomes        ProcessingOutcomeLine[]

  @@index([session_id, asset_id])
}

model ProcessingOutcomeLine {
  id                          String         @id @default(uuid())
  processing_record_id        String
  material_fraction           String
  fraction_id                 String?
  weight_kg                   Decimal
  treatment_route             TreatmentRoute
  acceptant_stage             AcceptantStage @default(FIRST_ACCEPTANT)
  process_description         String?
  share_pct                   Decimal        @default(0)
  prepared_for_reuse_pct      Decimal        @default(0)
  recycling_pct               Decimal        @default(0)
  other_material_recovery_pct Decimal        @default(0)
  energy_recovery_pct         Decimal        @default(0)
  thermal_disposal_pct        Decimal        @default(0)
  notes                       String?
  created_at                  DateTime       @default(now())

  processing_record ProcessingRecord @relation(fields: [processing_record_id], references: [id])
  fraction          FractionMaster?  @relation(fields: [fraction_id], references: [id])
}

model Processor {
  id                          String   @id @default(uuid())
  name                        String
  address                     String
  country                     String
  environmental_permit_number String
  is_weeelabex_listed         Boolean  @default(false)
  is_active                   Boolean  @default(true)
  created_at                  DateTime @default(now())
  updated_at                  DateTime @updatedAt

  certificates ProcessorCertificate[]
}

model ProcessorCertificate {
  id                 String   @id @default(uuid())
  processor_id       String
  certificate_number String
  certification_body String
  valid_from         DateTime
  valid_to           DateTime
  document_url       String?
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  processor Processor                           @relation(fields: [processor_id], references: [id])
  materials ProcessorCertificateMaterialScope[]
}

model ProcessorCertificateMaterialScope {
  id             String @id @default(uuid())
  certificate_id String
  material_id    String @map("product_type_id")

  certificate ProcessorCertificate @relation(fields: [certificate_id], references: [id])
  material    MaterialMaster       @relation(fields: [material_id], references: [id])

  @@unique([certificate_id, material_id])
  @@map("ProcessorCertificateProductType")
}

model ReusableItem {
  id                 String   @id @default(uuid())
  catalogue_entry_id String
  material_id        String
  brand              String?
  model_name         String?
  type               String?
  serial_number      String?
  condition          String?
  notes              String?
  created_at         DateTime @default(now())

  catalogue_entry AssetCatalogueEntry @relation(fields: [catalogue_entry_id], references: [id], onDelete: Cascade)
  material        MaterialMaster      @relation(fields: [material_id], references: [id])

  @@index([catalogue_entry_id])
}

model FeeMaster {
  id          String      @id @default(uuid())
  fee_type    String
  description String
  rate_type   FeeRateType
  rate_value  Decimal
  min_cap     Decimal?
  max_cap     Decimal?
  is_active   Boolean     @default(true)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  contract_penalties      ContractContaminationPenalty[]
  contamination_incidents ContaminationIncident[]

  @@index([fee_type])
}

model SupplierContract {
  id              String         @id @default(uuid())
  contract_number String         @unique
  supplier_id     String?
  carrier_id      String?
  name            String
  effective_date  DateTime
  expiry_date     DateTime?
  status          ContractStatus @default(ACTIVE)
  receiver_name   String         @default("Statice B.V.")

  payment_term_days       Int                @default(30)
  invoicing_frequency     InvoicingFrequency @default(MONTHLY)
  currency                String             @default("EUR")
  invoice_delivery_method String?

  contamination_tolerance_pct Decimal @default(0)

  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  contract_type            ContractType @default(INCOMING)
  agreement_transporter_id String?
  invoice_entity_id        String?
  entity_supplier_id       String?

  // Outgoing-specific fields
  buyer_id        String?
  sender_id       String?
  disposer_id     String?
  disposer_site_id String?
  shipment_type   ShipmentType?

  supplier                Supplier?                      @relation(fields: [supplier_id], references: [id])
  carrier                 Carrier?                       @relation(fields: [carrier_id], references: [id])
  entity_supplier         Entity?                        @relation("ContractSupplier", fields: [entity_supplier_id], references: [id])
  agreement_transporter   Entity?                        @relation("ContractTransporter", fields: [agreement_transporter_id], references: [id])
  invoice_entity          Entity?                        @relation("ContractInvoiceEntity", fields: [invoice_entity_id], references: [id])
  buyer                   Entity?                        @relation("ContractBuyer", fields: [buyer_id], references: [id])
  sender                  Entity?                        @relation("ContractSender", fields: [sender_id], references: [id])
  disposer                Entity?                        @relation("ContractDisposer", fields: [disposer_id], references: [id])
  disposer_site           DisposerSite?                  @relation("ContractDisposerSite", fields: [disposer_site_id], references: [id])
  rate_lines              ContractRateLine[]
  contamination_penalties ContractContaminationPenalty[]
  contract_waste_streams  ContractWasteStream[]
  invoices                Invoice[]
  outbound_orders         OutboundOrder[]

  @@index([supplier_id])
  @@index([carrier_id])
  @@index([entity_supplier_id])
  @@index([agreement_transporter_id])
  @@index([buyer_id])
  @@index([status])
  @@index([expiry_date])
}

model ContractRateLine {
  id                       String       @id @default(uuid())
  contract_id              String
  contract_waste_stream_id String?
  material_id              String
  pricing_model            PricingModel
  unit_rate                Decimal
  btw_rate                 Decimal      @default(0)
  processing_method        String?
  valid_from               DateTime
  valid_to                 DateTime?
  superseded_at            DateTime?
  created_at               DateTime     @default(now())

  contract              SupplierContract     @relation(fields: [contract_id], references: [id])
  contract_waste_stream ContractWasteStream? @relation(fields: [contract_waste_stream_id], references: [id])
  material              MaterialMaster       @relation(fields: [material_id], references: [id])

  @@index([contract_id, material_id])
  @@index([contract_waste_stream_id])
  @@index([valid_from, valid_to])
}

model ContractWasteStream {
  id                String   @id @default(uuid())
  contract_id       String
  waste_stream_id   String
  afvalstroomnummer String
  receiver_id       String?
  created_at        DateTime @default(now())

  contract     SupplierContract   @relation(fields: [contract_id], references: [id])
  waste_stream WasteStream        @relation(fields: [waste_stream_id], references: [id])
  receiver     Entity?            @relation("CWSReceiver", fields: [receiver_id], references: [id])
  rate_lines   ContractRateLine[]

  @@unique([contract_id, waste_stream_id])
  @@index([contract_id])
}

model ContractContaminationPenalty {
  id          String @id @default(uuid())
  contract_id String
  fee_id      String

  contract SupplierContract @relation(fields: [contract_id], references: [id])
  fee      FeeMaster        @relation(fields: [fee_id], references: [id])

  @@unique([contract_id, fee_id])
}

model Invoice {
  id                String        @id @default(uuid())
  invoice_number    String        @unique
  status            InvoiceStatus @default(DRAFT)
  supplier_id       String
  contract_id       String
  invoice_date      DateTime
  due_date          DateTime
  currency          String        @default("EUR")
  subtotal          Decimal       @default(0)
  btw_total         Decimal       @default(0)
  total_amount      Decimal       @default(0)
  notes             String?
  recipient_name    String
  recipient_address String?
  created_by        String
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  supplier        Supplier         @relation(fields: [supplier_id], references: [id])
  contract        SupplierContract @relation(fields: [contract_id], references: [id])
  created_by_user User             @relation(fields: [created_by], references: [id])
  lines           InvoiceLine[]

  @@index([supplier_id])
  @@index([contract_id])
  @@index([status])
  @@index([invoice_date])
}

model InvoiceLine {
  id                        String   @id @default(uuid())
  invoice_id                String
  order_id                  String?
  material_id               String?
  description               String
  line_type                 String   @default("material")
  quantity                  Decimal
  unit                      String   @default("kg")
  unit_rate                 Decimal
  btw_rate                  Decimal  @default(0)
  line_subtotal             Decimal
  btw_amount                Decimal  @default(0)
  line_total                Decimal
  contamination_incident_id String?
  rate_line_id              String?
  sort_order                Int      @default(0)
  created_at                DateTime @default(now())

  invoice                Invoice                @relation(fields: [invoice_id], references: [id])
  order                  InboundOrder?          @relation(fields: [order_id], references: [id])
  material               MaterialMaster?        @relation(fields: [material_id], references: [id])
  contamination_incident ContaminationIncident? @relation(fields: [contamination_incident_id], references: [id])

  @@index([invoice_id])
  @@index([order_id])
}

model ContaminationIncident {
  id                      String            @id @default(uuid())
  incident_number         String            @unique
  order_id                String
  sorting_session_id      String?
  contamination_type      ContaminationType
  description             String
  contamination_weight_kg Decimal?
  contamination_pct       Decimal?
  estimated_hours         Decimal?
  fee_amount              Decimal?
  fee_master_id           String?
  is_invoiced             Boolean           @default(false)
  recorded_by             String
  recorded_at             DateTime          @default(now())
  notes                   String?

  order            InboundOrder    @relation(fields: [order_id], references: [id])
  sorting_session  SortingSession? @relation(fields: [sorting_session_id], references: [id])
  fee_master       FeeMaster?      @relation(fields: [fee_master_id], references: [id])
  recorded_by_user User            @relation(fields: [recorded_by], references: [id])
  invoice_lines    InvoiceLine[]

  @@index([order_id])
  @@index([sorting_session_id])
}

// ─── Outbound Models ───────────────────────────────────────────────────────

model OutboundOrder {
  id                      String              @id @default(uuid())
  order_number            String              @unique @map("order_number")
  contract_id             String              @map("contract_id")
  buyer_id                String              @map("buyer_id")
  sender_id               String              @map("sender_id")
  disposer_id             String              @map("disposer_id")
  disposer_site_id        String?             @map("disposer_site_id")
  transporter_id          String              @map("transporter_id")
  outsourced_transporter_id String?           @map("outsourced_transporter_id")
  vehicle_plate           String?             @map("vehicle_plate")
  planned_date            DateTime            @map("planned_date")
  planned_time_start      DateTime?           @map("planned_time_start")
  planned_time_end        DateTime?           @map("planned_time_end")
  shipment_type           ShipmentType        @map("shipment_type")
  expected_outbounds      Int                 @default(1) @map("expected_outbounds")
  status                  OutboundOrderStatus @default(PLANNED)
  notes                   String?
  created_by              String              @map("created_by")
  created_at              DateTime            @default(now()) @map("created_at")
  updated_at              DateTime            @updatedAt @map("updated_at")

  contract                SupplierContract     @relation(fields: [contract_id], references: [id])
  buyer                   Entity              @relation("OutboundOrderBuyer", fields: [buyer_id], references: [id])
  sender                  Entity              @relation("OutboundOrderSender", fields: [sender_id], references: [id])
  disposer                Entity              @relation("OutboundOrderDisposer", fields: [disposer_id], references: [id])
  transporter             Entity              @relation("OutboundOrderTransporter", fields: [transporter_id], references: [id])
  outsourced_transporter  Entity?             @relation("OutboundOrderOutsourcedTransporter", fields: [outsourced_transporter_id], references: [id])
  disposer_site           DisposerSite?       @relation("OutboundOrderDisposerSite", fields: [disposer_site_id], references: [id])
  created_by_user         User                @relation(fields: [created_by], references: [id])
  waste_streams           OutboundOrderWasteStream[]
  outbounds               Outbound[]

  @@map("outbound_orders")
  @@index([contract_id])
  @@index([buyer_id])
  @@index([status])
}

model OutboundOrderWasteStream {
  id                String   @id @default(uuid())
  outbound_order_id String   @map("outbound_order_id")
  waste_stream_id   String   @map("waste_stream_id")
  receiver_id       String   @map("receiver_id")
  asn               String?
  material_id       String?  @map("material_id")
  processing_method String?  @map("processing_method")
  planned_amount_kg Decimal? @map("planned_amount_kg") @db.Decimal(12, 2)

  outbound_order OutboundOrder @relation(fields: [outbound_order_id], references: [id])
  waste_stream   WasteStream   @relation(fields: [waste_stream_id], references: [id])
  receiver       Entity        @relation("OOWSReceiver", fields: [receiver_id], references: [id])

  @@unique([outbound_order_id, waste_stream_id])
  @@map("outbound_order_waste_streams")
}

model Outbound {
  id                    String         @id @default(uuid())
  outbound_number       String         @unique @map("outbound_number")
  outbound_order_id     String         @map("outbound_order_id")
  vehicle_plate         String?        @map("vehicle_plate")
  status                OutboundStatus @default(CREATED)
  gross_weight_kg       Decimal?       @map("gross_weight_kg") @db.Decimal(12, 2)
  tare_weight_kg        Decimal?       @map("tare_weight_kg") @db.Decimal(12, 2)
  net_weight_kg         Decimal?       @map("net_weight_kg") @db.Decimal(12, 2)
  loading_started_at    DateTime?      @map("loading_started_at")
  weighing_completed_at DateTime?      @map("weighing_completed_at")
  documents_ready_at    DateTime?      @map("documents_ready_at")
  departed_at           DateTime?      @map("departed_at")
  delivered_at          DateTime?      @map("delivered_at")
  notes                 String?
  created_by            String         @map("created_by")
  created_at            DateTime       @default(now()) @map("created_at")
  updated_at            DateTime       @updatedAt @map("updated_at")

  outbound_order   OutboundOrder           @relation(fields: [outbound_order_id], references: [id])
  weighing_records OutboundWeighingRecord[]
  documents        OutboundDocument[]
  parcels          OutboundParcel[]

  @@map("outbounds")
  @@index([outbound_order_id])
  @@index([status])
}

model OutboundWeighingRecord {
  id               String              @id @default(uuid())
  outbound_id      String              @map("outbound_id")
  weighing_type    OutboundWeighingType @map("weighing_type")
  weight_kg        Decimal             @map("weight_kg") @db.Decimal(12, 2)
  source           WeighingSource      @default(SCALE)
  pfister_ticket_id String?            @unique @map("pfister_ticket_id")
  ticket_number    String?             @map("ticket_number")
  recorded_by      String              @map("recorded_by")
  recorded_at      DateTime            @default(now()) @map("recorded_at")
  notes            String?

  outbound       Outbound       @relation(fields: [outbound_id], references: [id])
  pfister_ticket PfisterTicket? @relation(fields: [pfister_ticket_id], references: [id])

  @@map("outbound_weighing_records")
  @@index([outbound_id])
}

model OutboundDocument {
  id            String                   @id @default(uuid())
  outbound_id   String                   @map("outbound_id")
  document_type OutboundDocumentType     @map("document_type")
  status        DocumentGenerationStatus @default(PENDING)
  file_name     String?                  @map("file_name")
  storage_path  String?                  @map("storage_path")
  generated_at  DateTime?                @map("generated_at")
  generated_by  String?                  @map("generated_by")

  outbound Outbound @relation(fields: [outbound_id], references: [id])

  @@map("outbound_documents")
  @@index([outbound_id])
}

model OutboundParcel {
  id                  String               @id @default(uuid())
  parcel_label        String               @unique @map("parcel_label")
  outbound_id         String?              @map("outbound_id")
  material_id         String               @map("material_id")
  container_type      SkipType             @map("container_type")
  volume_m3           Decimal?             @map("volume_m3") @db.Decimal(8, 2)
  tare_weight_kg      Decimal?             @map("tare_weight_kg") @db.Decimal(12, 2)
  description         String?
  notes               String?
  status              OutboundParcelStatus @default(AVAILABLE)
  created_by          String               @map("created_by")
  created_at          DateTime             @default(now()) @map("created_at")
  updated_at          DateTime             @updatedAt @map("updated_at")

  outbound Outbound?      @relation(fields: [outbound_id], references: [id])
  material MaterialMaster @relation(fields: [material_id], references: [id])

  @@map("outbound_parcels")
  @@index([outbound_id])
  @@index([material_id])
  @@index([status])
}
